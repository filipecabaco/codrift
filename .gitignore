# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Temporary files
/tmp/

# Claude Code agent worktrees and session data
.claude/

# Dialyzer PLT files (cached in CI, not committed)
/priv/plts/*.plt
/priv/plts/*.plt.hash

# Built web UI artifacts (generated from assets/ by `vite build`).
# The diff.html / term.html prototypes are hand-written and stay tracked.
/priv/static/index.html
/priv/static/assets/

# Tauri Rust build output
/assets/src-tauri/target/
/assets/src-tauri/gen/
